# aws.env — aws-wechat 全套件共享密钥（dotenv：一行一个 KEY=value；# 注释；不是 JSON）
# 权威键集来自 aws-wechat-article-assets/scripts/import_presets_aws.py 的 SECRET_FIELD_MAP
# + 各 skill frontmatter requires.env。模型的 base_url/model 在 .aws-article/config.yaml，
# 这里只放密钥（API key）与公众号凭证。

# ── 模型密钥（与 config.yaml 的 image_model / writing_model 配对）──
IMAGE_MODEL_API_KEY=          # 配图必填（aws-wechat-article-images / -sticker / -main）
WRITING_MODEL_API_KEY=        # 写稿用（aws-wechat-article-writing / -main）；只配图可空

# ── 公众号账号 1（发布用：aws-wechat-article-publish / -main / -sticker）──
WECHAT_1_APPID=
WECHAT_1_APPSECRET=
# WECHAT_1_API_BASE=          # 可选；空=官方 https://api.weixin.qq.com，走中转才填

# ── 多账号（仅当 config.yaml 的 wechat_accounts ≥ 2 时启用对应槽位）──
# WECHAT_2_APPID=
# WECHAT_2_APPSECRET=
# WECHAT_2_API_BASE=
